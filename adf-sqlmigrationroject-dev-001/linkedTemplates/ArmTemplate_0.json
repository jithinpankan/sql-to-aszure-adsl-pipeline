{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adf-sqlmigrationroject-dev-001"
		},
		"LS_SqlTable_Parquet_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'LS_SqlTable_Parquet'"
		},
		"DS_LKP_MAX_VALUE_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'DS_LKP_MAX_VALUE'"
		},
		"LS_SQLSERVER_TBLLKP_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'LS_SQLSERVER_TBLLKP'"
		},
		"LS_SqlTable_Parquet_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://stmigrationprojectdev001.dfs.core.windows.net/"
		},
		"DS_LKP_MAX_VALUE_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "BDC7-L-69BYPP3\\SQLEXPRESS"
		},
		"DS_LKP_MAX_VALUE_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "adfsourcedb"
		},
		"DS_LKP_MAX_VALUE_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "adfuser"
		},
		"LS_SQLSERVER_TBLLKP_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "BDC7-L-69BYPP3\\SQLEXPRESS"
		},
		"LS_SQLSERVER_TBLLKP_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "adfsourcedb"
		},
		"LS_SQLSERVER_TBLLKP_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "adfuser"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
