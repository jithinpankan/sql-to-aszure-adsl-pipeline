		"LS_SQLSERVER_TBLLKP_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "BDC7-L-69BYPP3\\SQLEXPRESS"
		},
		"LS_SQLSERVER_TBLLKP_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "adfsourcedb"
		},
		"LS_SQLSERVER_TBLLKP_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "adfuser"
		},
