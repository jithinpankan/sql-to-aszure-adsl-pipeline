					},
					"LS_SQLSERVER_TBLLKP_properties_typeProperties_database": {
						"value": "[parameters('LS_SQLSERVER_TBLLKP_properties_typeProperties_database')]"
					},
					"LS_SQLSERVER_TBLLKP_properties_typeProperties_userName": {
						"value": "[parameters('LS_SQLSERVER_TBLLKP_properties_typeProperties_userName')]"
